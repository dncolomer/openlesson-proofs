  "types": [
    {
      "name": "BatchAnchor",
      "docs": [
        "Merkle root of a batch of session proofs (heartbeats + assistant queries).",
        "PDA seeds: [\"batch\", batch_id]"
      ],
      "type": {
        "kind": "struct",
